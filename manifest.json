{
  "manifest_version": 3,
  "name": "Pavo AI — Sidepanel Agent That Browses and Acts for You",
  "version": "1.0.0",
  "description": "AI-powered browser agent with streaming chat interface",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting", "commands", "tabGroups"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Pavo"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_side_panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Ctrl+Shift+X"
      },
      "description": "Open Twitter Agent"
    }
  }
}
